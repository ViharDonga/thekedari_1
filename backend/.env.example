# PostgreSQL 18 (port 5433) — local pgAdmin setup
# No Docker. Do NOT use port 5432 (that is PostgreSQL 17).

DATABASE_URL="postgresql://vihar:vihar2203@localhost:5433/thekedari?schema=public"
PORT=3000
JWT_SECRET="thekedari-local-secret"

# If password has special characters, URL-encode them (@ -> %40)

# Setup steps:
# 1. Connect pgAdmin to PostgreSQL 18: localhost, port 5433, user postgres
# 2. Run backend/prisma/setup-pg18.sql in Query Tool
# 3. Register pgAdmin server again with user vihar / vihar2203
# 4. npx prisma migrate deploy && npm run prisma:seed && npm run start:dev
